        <mxCell id="1" parent="0" />
        <mxCell id="NXcHPpBootGxJ3cSa07u-17" parent="1" style="shape=process;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#b1ddf0;strokeColor=#10739e;fontColor=#000000;" value="Post-Processor &lt;b&gt;(optional)&lt;/b&gt;" vertex="1">
          <mxGeometry height="60" width="389" x="185" y="362" as="geometry" />
        </mxCell>
        <mxCell id="NXcHPpBootGxJ3cSa07u-11" parent="1" style="shape=process;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#ffff88;strokeColor=#36393d;fontColor=#000000;" value="Input Parser" vertex="1">
          <mxGeometry height="60" width="390" x="184" y="162" as="geometry" />
        </mxCell>
        <mxCell id="NXcHPpBootGxJ3cSa07u-15" parent="1" style="shape=process;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#ffcccc;strokeColor=#36393d;fontColor=#000000;" value="Output Generator" vertex="1">
          <mxGeometry height="60" width="389" x="185" y="262" as="geometry" />
        </mxCell>
        <mxCell id="NXcHPpBootGxJ3cSa07u-13" parent="1" style="rounded=0;whiteSpace=wrap;html=1;dashed=1;dashPattern=8 8;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=3;fontColor=#000000;" value="input_parser_response_object&lt;div&gt;&lt;i&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;(&lt;b&gt;Response object A&lt;/b&gt;)&lt;/font&gt;&lt;/i&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="60" width="250" x="264" y="212" as="geometry" />
        </mxCell>
        <mxCell id="NXcHPpBootGxJ3cSa07u-16" parent="1" style="rounded=0;whiteSpace=wrap;html=1;dashed=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=3;fontColor=#000000;" value="output_generator_response_object&lt;div&gt;&lt;i&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;(&lt;b&gt;Response object B&lt;/b&gt;)&lt;/font&gt;&lt;/i&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="60" width="250" x="264" y="312" as="geometry" />
        </mxCell>
        <mxCell id="NXcHPpBootGxJ3cSa07u-19" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Standard workflow; data exchange between &lt;font face=&quot;Helvetica&quot;&gt;Input Parser, Output Generator and Post-Processor&lt;/font&gt;&lt;/h1&gt;&lt;p&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;font style=&quot;font-size: 15px;&quot;&gt;&lt;b style=&quot;&quot;&gt;Input Parser&lt;/b&gt; and &lt;b&gt;Output Generator&lt;/b&gt; share mutual response object A&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 15px;&quot;&gt;&lt;b&gt;Output Generator&lt;/b&gt; and &lt;b&gt;Post-Processor&lt;/b&gt; share mutual response object B&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 15px;&quot;&gt;Response objects A and B may be identical or different&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 15px;&quot;&gt;Both response objects A and B can have any data type.&amp;nbsp;&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;&quot;&gt;&lt;span style=&quot;font-size: 15px;&quot;&gt;core-aprs-client uses the output structure of the &lt;b&gt;Input Parser&lt;/b&gt; and assigns it as input to the &lt;b&gt;Output Generator&lt;/b&gt;. There is no access to this data structure within core-aprs-client.&lt;/span&gt;&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 15px;&quot;&gt;A &#39;dict&#39; object is usually used for data transfer between the respective subroutines.&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 15px;&quot;&gt;The use of the &lt;b&gt;Post-Processor&lt;/b&gt; is optional. It requires the user to specify a custom post-processor function &lt;b style=&quot;text-decoration-line: underline;&quot;&gt;and&lt;/b&gt; the Output Generator function to provide post-processing data.&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 15px;&quot;&gt;The use of the &lt;b&gt;Pre-Processor&lt;/b&gt; is also optional. This function allows you to perform any necessary preparatory work for processing before the actual parsing of the APRS input message (if required). It is also possible to send any APRS output message to the user before parsing the APRS input message.&amp;nbsp;The pre-processor and input parser do &lt;b&gt;not &lt;/b&gt;have any common data exchange areas.&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="418" width="550" x="134" y="452" as="geometry" />
        </mxCell>
        <mxCell id="NXcHPpBootGxJ3cSa07u-25" edge="1" parent="1" style="shape=flexArrow;endArrow=classic;html=1;rounded=0;fillColor=#b0e3e6;strokeColor=#0e8088;" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
